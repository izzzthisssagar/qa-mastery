{
  "name": "qa-mastery",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:rls": "pnpm --filter @qa-mastery/db test:rls",
    "e2e": "turbo build && pnpm --filter @qa-mastery/e2e e2e",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status"
  },
  "devDependencies": {
    "supabase": "^2.106.0",
    "turbo": "^2.9.18"
  }
}
