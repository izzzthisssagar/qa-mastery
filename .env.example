# ── Supabase (local values come from `pnpm db:start` / `supabase status`) ──
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
# Server-only. Grading, sandbox provisioning, curriculum sync. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# ── Sandbox session handoff (shared by platform + buggyshop) ──
# Generate: openssl rand -base64 32
SANDBOX_JWT_SECRET=dev-only-secret-change-me

# ── App URLs (used for iframe CSP frame-ancestors + back-links) ──
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3000
NEXT_PUBLIC_BUGGYSHOP_URL=http://localhost:3001

# ── Billing (M3 — keep disabled until launch) ──
BILLING_ENABLED=false
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=

# ── Analytics (optional in dev) ──
# NEXT_PUBLIC_POSTHOG_KEY=

# ── Admin (founder email allowlist, comma-separated) ──
ADMIN_EMAILS=izzzthisssagar@gmail.com

# ── Help-agent tutor LLM (free by default) ──
# Auto-resolution order: Ollama (local) → Gemini → Groq (all free) → xAI/OpenAI
# (paid, used only if no free key is set or selected explicitly). Set ONE free
# option to run the tutor for free. Override with HELP_AGENT_PROVIDER=<name>.
# GEMINI_API_KEY=            # free tier — the recommended free default
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=              # free tier
# OLLAMA_BASE_URL=http://127.0.0.1:11434   # fully local, free; OLLAMA_MODEL=llama3.2:3b
# XAI_API_KEY=               # paid (Grok) — opt-in: HELP_AGENT_PROVIDER=xai
# OPENAI_API_KEY=            # paid — opt-in: HELP_AGENT_PROVIDER=openai
# HELP_AGENT_PROVIDER=auto
