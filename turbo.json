{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NEXT_PUBLIC_*", "SUPABASE_*", "SANDBOX_JWT_SECRET", "BILLING_ENABLED", "ADMIN_EMAILS", "HELP_AGENT_*", "OLLAMA_*", "GEMINI_*", "GROQ_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "test": {}
  }
}
